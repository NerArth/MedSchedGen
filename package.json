{
    "name": "med-sched-gen",
    "version": "1.2.0",
    "description": "Generate medication-taking schedules which can then be printed off for real-world usage.",
    "author": "NerArth",
    "license": "SEE LICENSE IN LICENSE.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/NerArth/MedSchedGen"
    },
    "scripts": {
        "build": "node .dev/build.js"
    },
    "build": {
        "source": {
            "html": "index.html",
            "css": "style.css",
            "js": "script.js"
        },
        "output": {
            "directory": "dist",
            "nameFormat": "MedSched_v{version}.html"
        }
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2"
    }
}
